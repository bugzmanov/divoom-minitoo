# Copy this file to personal.env and fill in your own values.
#   cp personal.env.example personal.env
#   source personal.env
#
# personal.env is gitignored.

# Bluetooth MAC of your Divoom device (run `system_profiler SPBluetoothDataType` on macOS to find it).
export DIVOOM_MAC="AA:BB:CC:DD:EE:FF"

# Divoom cloud DeviceId. Discoverable via the Divoom mobile app or by capturing a request to
# https://appin.divoom-gz.com — see fetch-clock-ids.py for the login flow.
export DIVOOM_DEVICE_ID="000000000"
